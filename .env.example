# Copy file này thành .env rồi điền credentials thật
# cp .env.example .env

# === MinIO / S3 ===
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_minio_password_here

# === PostgreSQL (Airflow backend) ===
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_postgres_password_here

# === Airflow Web UI ===
AIRFLOW_WWW_USER=airflow
AIRFLOW_WWW_PASSWORD=your_airflow_password_here

# === Spark Master SSH (dùng bởi Airflow Scheduler) ===
SPARK_SSH_PASSWORD=your_spark_ssh_password_here

